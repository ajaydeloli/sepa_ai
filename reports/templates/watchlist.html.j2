<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SEPA Watchlist — {{ run_date }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0d1117;
      color: #c9d1d9;
      font-size: 14px;
      padding: 24px 16px 48px;
    }
    a { color: #58a6ff; text-decoration: none; }

    /* ── Header ── */
    .page-header {
      display: flex; flex-wrap: wrap; align-items: baseline;
      gap: 12px; margin-bottom: 20px;
    }
    .page-header h1 {
      font-size: 1.5rem; font-weight: 700; color: #f0f6fc;
    }
    .run-date { color: #8b949e; font-size: 0.9rem; }

    /* ── Summary bar ── */
    .summary-bar {
      display: flex; flex-wrap: wrap; gap: 8px;
      background: #161b22; border: 1px solid #30363d;
      border-radius: 8px; padding: 12px 16px; margin-bottom: 24px;
    }
    .stat-chip {
      display: inline-flex; align-items: center; gap: 5px;
      background: #21262d; border-radius: 20px;
      padding: 3px 10px; font-size: 0.8rem; color: #8b949e;
    }
    .stat-chip strong { color: #f0f6fc; }
  </style>
</head>

  <style>
    /* ── Quality badges ── */
    .badge {
      display: inline-block; border-radius: 4px;
      padding: 2px 7px; font-size: 0.75rem; font-weight: 700;
      letter-spacing: 0.03em; white-space: nowrap;
    }
    .badge-aplus  { background: #3d2f00; color: #e3a614; border: 1px solid #e3a614; }
    .badge-a      { background: #0d2e1a; color: #3fb950; border: 1px solid #3fb950; }
    .badge-b      { background: #0c1e3a; color: #58a6ff; border: 1px solid #58a6ff; }
    .badge-c      { background: #1c1c24; color: #8b949e; border: 1px solid #484f58; }
    .badge-fail   { background: #2d0f0f; color: #f85149; border: 1px solid #f85149; }

    .star { color: #e3a614; margin-left: 4px; font-size: 0.85rem; }

    /* ── Main table ── */
    .table-wrap { overflow-x: auto; }
    table {
      width: 100%; border-collapse: collapse;
      min-width: 760px;
    }
    thead tr {
      background: #161b22; border-bottom: 2px solid #30363d;
    }
    thead th {
      padding: 10px 12px; text-align: left;
      font-size: 0.75rem; text-transform: uppercase;
      letter-spacing: 0.06em; color: #8b949e; white-space: nowrap;
    }
    tbody tr { border-bottom: 1px solid #21262d; }
    tbody tr:hover { background: #161b22; }
    tbody td {
      padding: 9px 12px; vertical-align: middle;
    }
    .sym { font-weight: 600; color: #f0f6fc; }
    .num { font-variant-numeric: tabular-nums; }
    .score-high { color: #3fb950; }
    .score-mid  { color: #e3a614; }
    .score-low  { color: #f85149; }

    /* ── LLM brief row ── */
    .brief-row td {
      padding: 6px 12px 12px 32px;
      font-size: 0.82rem; color: #8b949e;
      background: #0d1117; border-bottom: 1px solid #21262d;
    }
    .brief-label {
      font-weight: 600; color: #58a6ff; margin-right: 6px;
    }

    /* ── Empty state ── */
    .empty-state {
      text-align: center; padding: 48px 16px;
      color: #8b949e; font-size: 1rem;
    }

    /* ── Footer ── */
    footer {
      margin-top: 32px; text-align: center;
      font-size: 0.78rem; color: #484f58;
    }
  </style>

<body>

  <!-- ══ Page header ══ -->
  <div class="page-header">
    <h1>SEPA Watchlist</h1>
    <span class="run-date">{{ run_date }}</span>
  </div>

  <!-- ══ Summary bar ══ -->
  <div class="summary-bar">
    <span class="stat-chip">Total screened <strong>{{ summary.total_screened }}</strong></span>
    <span class="stat-chip">A+ <strong>{{ summary.a_plus }}</strong></span>
    <span class="stat-chip">A <strong>{{ summary.a }}</strong></span>
    <span class="stat-chip">B <strong>{{ summary.b }}</strong></span>
    <span class="stat-chip">C <strong>{{ summary.c }}</strong></span>
    <span class="stat-chip">Fail <strong>{{ summary.fail }}</strong></span>
    <span class="stat-chip">Stage 2 <strong>{{ summary.stage2_count }}</strong></span>
  </div>

  <!-- ══ Watchlist table ══ -->
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Symbol</th>
          <th>Score</th>
          <th>Quality</th>
          <th>Stage</th>
          <th>TT</th>
          <th>VCP</th>
          <th>Entry</th>
          <th>Stop</th>
          <th>Risk&nbsp;%</th>
          <th>RS</th>
        </tr>
      </thead>
      <tbody>

        {%- if no_candidates %}
        <tr>
          <td colspan="11" class="empty-state">No candidates meet the screening criteria for {{ run_date }}.</td>
        </tr>
        {%- else %}
        {%- for row in rows %}
        {%- set q = row.setup_quality %}
        {%- if   q == "A+" %}{%- set badge_cls = "badge-aplus" %}
        {%- elif q == "A"  %}{%- set badge_cls = "badge-a" %}
        {%- elif q == "B"  %}{%- set badge_cls = "badge-b" %}
        {%- elif q == "C"  %}{%- set badge_cls = "badge-c" %}
        {%- else            %}{%- set badge_cls = "badge-fail" %}
        {%- endif %}
        {%- set score_cls = "score-high" if row.score >= 80 else ("score-mid" if row.score >= 60 else "score-low") %}
        <tr>
          <td class="num">{{ row.rank }}</td>
          <td class="sym">
            {{ row.symbol }}
            {%- if row.is_watchlist %}<span class="star" title="On watchlist">★</span>{% endif %}
          </td>
          <td class="num {{ score_cls }}">{{ "%.1f"|format(row.score) }}</td>
          <td><span class="badge {{ badge_cls }}">{{ q }}</span></td>
          <td class="num">{{ row.stage }}</td>
          <td class="num">{{ row.conditions_met }}</td>
          <td>{{ "✓" if row.vcp_qualified else "–" }}</td>
          <td class="num">{{ "$%.2f"|format(row.entry_price) if row.entry_price else "–" }}</td>
          <td class="num">{{ "$%.2f"|format(row.stop_loss) if row.stop_loss else "–" }}</td>
          <td class="num">{{ "%.1f%%"|format(row.risk_pct) if row.risk_pct else "–" }}</td>
          <td class="num">{{ row.rs_rating if row.rs_rating else "–" }}</td>
        </tr>
        {%- if has_briefs and row.brief %}
        <tr class="brief-row">
          <td colspan="11">
            <span class="brief-label">AI Brief:</span>{{ row.brief }}
          </td>
        </tr>
        {%- endif %}
        {%- endfor %}
        {%- endif %}
      </tbody>
    </table>
  </div>

  <footer>Generated by SEPA AI at {{ generated_at }}</footer>

</body>
</html>
