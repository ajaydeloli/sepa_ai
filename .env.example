ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8000/callback

# ── LLM Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...          # free at console.groq.com — recommended default
OPENROUTER_API_KEY=sk-or-...  # deepseek-r1:free available
OLLAMA_BASE_URL=http://localhost:11434

# ── News ───────────────────────────────────────────────────────────────────────
